# Claude Approver Server Configuration
# Copy this file to config.env and fill in your values

# --- Basic ---
# PORT=8765
# AUTH_TOKEN=your_password_here

# --- Tunnel ---
TUNNEL=ngrok
# NGROK_AUTHTOKEN=your_ngrok_authtoken

# --- WeChat Push (pick one) ---
# SERVERCHAN_KEY=your_sendkey      # https://sct.ftqq.com
# PUSHPLUS_TOKEN=your_token        # https://www.pushplus.plus

# --- Email Push ---
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_TO=
